# ========================================
# Notion 集成（必填，用于同步数据库）
# ========================================
# 在 https://www.notion.so/my-integrations 创建 Integration
# 然后将其连接到你的项目数据库和周报数据库
NOTION_TOKEN=your_notion_integration_token_here
NOTION_DB_PROJECTS=39699f68-46fd-812a-87b6-de3cfab638ad
NOTION_DB_WEEKLY=39699f68-46fd-81ab-92f3-e46453692025

# ========================================
# MiniMax API（用于周报 AI 结构化，可选）
# ========================================
MINIMAX_API_KEY=your_minimax_api_key_here

# ========================================
# Upstash Redis（生产环境必填）
# ========================================
# 在 Vercel Marketplace 中安装 Upstash Redis 即可自动注入以下变量
# 本地开发不需要配置，会自动使用 JSON 文件存储
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...
